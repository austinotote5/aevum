{
  "name": "server",
  "version": "1.0.0",
  "description": "AEVUM API Server",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "lint:server": "node server/scripts/lintServer.js",
    "test:contracts": "node server/tests/api-contract.smoke.js",
    "test:client": "npm --prefix client run test",
    "build:client": "npm --prefix client run build",
    "ci:check": "npm run lint:server && npm run test:contracts && npm run test:client && npm run build:client",
    "proof:28d": "node server/scripts/export28DayProof.js",
    "data:purge-synthetic": "node server/scripts/purgeSyntheticData.js",
    "onboarding:push": "node server/scripts/generateOnboardingPush.js",
    "paid:convert": "node server/scripts/convertUserToPaid.js",
    "growth:friday": "node server/scripts/fridayGrowthCycle.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.0.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
